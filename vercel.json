{
  "rewrites": [
    { "source": "/api/auth/setup", "destination": "/api/data?action=setup" },
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    { "source": "/api/properties/:id", "destination": "/api/properties?id=:id" },
    { "source": "/api/landlords/:id", "destination": "/api/landlords?id=:id" },
    { "source": "/api/bookings/:id", "destination": "/api/bookings?id=:id" },
    { "source": "/api/guests/:id", "destination": "/api/guests?id=:id" },
    { "source": "/api/data/:action", "destination": "/api/data?action=:action" },
    { "source": "/api/db/:action", "destination": "/api/data?action=:action" },
    { "source": "/api/reports/:type", "destination": "/api/reports?type=:type" },
    { "source": "/api/invoices/receipt", "destination": "/api/reports?type=receipt" },
    { "source": "/api/invoices/payout", "destination": "/api/reports?type=payout" },
    { "source": "/api/portal/:action", "destination": "/api/portal?action=:action" },
    { "source": "/api/team/members/:id", "destination": "/api/team?action=members&memberId=:id" },
    { "source": "/api/team/:action", "destination": "/api/team?action=:action" },
    { "source": "/api/settings", "destination": "/api/data?action=settings" },
    { "source": "/api/activity", "destination": "/api/data?action=activity" },
    { "source": "/api/activity/:id", "destination": "/api/data?action=activity" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/icon-192.png", "destination": "/icon-192.png" },
    { "source": "/icon-512.png", "destination": "/icon-512.png" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
